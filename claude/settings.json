{
  "permissions": {
    "allow": [
      "Bash(gh pr*:*)",
      "Bash(cd:*)",
      "Bash(ug:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(eza:*)",
      "Bash(exa:*)",
      "Bash(ls:*)",
      "Bash(sd:*)",
      "Bash(git show:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(exa:*)",
      "Bash(ug:*)",
      "Bash(fd:*)",
      "Bash(sd:*)",
      "Bash(xargs:*)",
      "Bash(git:*)",
      "Bash(ug*:*)",
      "Bash(ug:*)",
      "Read(~/.claude/plans/)"
    ],
    "deny": [
      "Bash(ls *:*)",
      "Bash(find *:*)",
      "Bash(grep *:*)"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "pwsh -NoProfile -File $HOME/.claude/statusline-command.ps1"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  }
}
